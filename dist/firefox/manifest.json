{
  "manifest_version": 3,
  "name": "YouTube Shorts Scroll Blocker",
  "version": "1.0.0",
  "description": "YouTube Shortsでスクロールやキー操作による次動画移動を無効化します。",
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://m.youtube.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-shorts-no-scroll@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
